{
  "name": "edgefleet-finance-backend",
  "version": "1.0.0",
  "description": "Backend services for EdgeFleet.AI Finance and Expense Tracking Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
